GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash
GEMINI_VERIFICATION_MODEL=gemini-2.5-flash
GEMINI_FORMAT_MODEL=gemini-2.5-flash
SLIDE_PROMPT_MODEL=gemini-2.5-flash
PDF_DIR=./pdfs
OUTPUT_DIR=./output_notes
POPPLER_PATH=C:\poppler\bin
DPI=250
MAX_RETRIES=4
GEMINI_DELAY_SECONDS=0
GEMINI_TIMEOUT_SECONDS=180
RESET_MASTER=false
CREATE_DOCX=true
TEST_MAX_PAGES=0
TEST_PDF_LIMIT=1
CREATE_STRUCTURED_NOTES=false
FORCE_REPROCESS_PAGES=false
USE_EMBEDDED_PDF_TEXT=true
EXACT_TEXT_ONLY=false
CLEAR_PROXY_ENV=local
MAX_PARALLEL_JOBS=2
TEST_START_PAGE=1
PAGE_WORKERS_PER_JOB=2
SPEED_MODE=fast
PROMPT_ENGINE_BATCH_SIZE=4
USE_PROMPT_ENGINE=true
PROMPT_ENGINE_MODE=interactive
DISABLE_INLINE_WORKERS=false
MAX_UPLOAD_MB=250
APP_USERNAME=team
APP_PASSWORD=change-this-password
