GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash
PDF_DIR=./pdfs
OUTPUT_DIR=./output_notes
POPPLER_PATH=C:\poppler\bin
DPI=250
MAX_RETRIES=5
GEMINI_DELAY_SECONDS=1
GEMINI_TIMEOUT_SECONDS=180
RESET_MASTER=false
CREATE_DOCX=true
TEST_MAX_PAGES=0
TEST_PDF_LIMIT=1
CREATE_STRUCTURED_NOTES=false
MAX_PARALLEL_JOBS=2
TEST_START_PAGE=1
PAGE_WORKERS_PER_JOB=1
SPEED_MODE=accuracy
MAX_UPLOAD_MB=250
APP_USERNAME=team
APP_PASSWORD=change-this-password
